// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccessStatus {
  ON_TIME
  LATE
}

enum ScheduleType {
  GENERAL
  SPECIAL
}

enum Role {
  ADMIN
  RRHH
  SUPERVISOR
  READ_ONLY
}

enum AuditStatus {
  SUCCESS
  FAILURE
  DENIED
}

enum PaymentType {
  MONTHLY
  BIWEEKLY
  WEEKLY
}

enum LateDiscountPolicy {
  BY_MINUTE
  BY_RANGE
}

enum LunchDeductionType {
  FIXED
  REAL_TIME
}

enum MarkType {
  ENTRY
  LUNCH_OUT
  LUNCH_IN
  EXIT
  INCIDENCE
}

model User {
  id                   Int                @id @default(autoincrement())
  email                String             @unique
  password             String
  name                 String?
  role                 Role               @default(ADMIN)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relaciones
  recordedAccesses     Access[]           @relation("UserRecordedAccesses")
  scheduleChanges      ScheduleHistory[]  @relation("UserScheduleChanges")
  createdJustifications Justification[]   @relation("UserCreatedJustifications")
  accessEditHistories  AccessEditHistory[]
  notifications        Notification[]
  auditLogs            AuditLog[]         @relation("ActorAuditLogs")
}

model Collaborator {
  id                  Int         @id @default(autoincrement())
  dni                 String      @unique
  name                String
  active              Boolean     @default(true)
  is_active           Boolean     @default(true)
  is_blocked          Boolean     @default(false)
  pin_hash            String?
  qr_token            String?     @unique
  photo_url           String?
  tags                String[]    @default([])
  // RRHH fields (Sprint 3)
  position            String?
  hireDate            DateTime?
  salary              Decimal?    @db.Decimal(12, 2)
  paymentType         PaymentType?
  scheduleSpecial     Schedule?   @relation("SpecialFor", fields: [scheduleSpecialId], references: [id])
  scheduleSpecialId   Int?
  accesses            Access[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model Access {
  id               Int             @id @default(autoincrement())
  collaborator     Collaborator    @relation(fields: [collaboratorId], references: [id])
  collaboratorId   Int
  timestamp        DateTime        @default(now())
  status           AccessStatus
  recordedBy       User?           @relation("UserRecordedAccesses", fields: [recordedById], references: [id])
  recordedById     Int?

  // Device metadata (kiosk removed)
  deviceFingerprint String?
  ip                String?
  photo_url         String?
  suspicious_reason String?
  confidence_flag   Boolean    @default(false)

  // Tipo de marcación automática (Sprint 5)
  markType         MarkType        @default(ENTRY)
  minutesLate      Int?            // minutos de tardanza (solo ENTRY, null si no aplica)

  // Justificación opcional
  justification     Justification?

  // Edit history
  editHistories    AccessEditHistory[]
}


model AccessEditHistory {
  id          Int      @id @default(autoincrement())
  access      Access   @relation(fields: [accessId], references: [id])
  accessId    Int
  editedBy    User     @relation(fields: [editedById], references: [id])
  editedById  Int
  oldData     Json
  newData     Json
  reason      String
  editedAt    DateTime @default(now())
}

model Justification {
  id             Int       @id @default(autoincrement())
  reason         String
  access         Access    @relation(fields: [accessId], references: [id])
  accessId       Int       @unique
  createdBy      User     @relation("UserCreatedJustifications", fields: [createdById], references: [id])
  createdById    Int
  createdAt      DateTime  @default(now())
}

model Schedule {
  id              Int               @id @default(autoincrement())
  type            ScheduleType
  days            String[]          // ["Mon","Tue","Wed","Thu","Fri"]
  startTime       String            // e.g. "08:30"
  specialFor      Collaborator[]    @relation("SpecialFor")
  history         ScheduleHistory[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model ScheduleHistory {
  id            Int        @id @default(autoincrement())
  schedule      Schedule   @relation(fields: [scheduleId], references: [id])
  scheduleId    Int
  changedBy     User      @relation("UserScheduleChanges", fields: [changedById], references: [id])
  changedById   Int
  oldStartTime  String
  newStartTime  String
  oldDays       String[]     @default([])
  newDays       String[]     @default([])
  oldType       ScheduleType?
  newType       ScheduleType?
  reason        String?
  changedAt     DateTime   @default(now())
}

model Notification {
  id          Int       @id @default(autoincrement())
  admin       User     @relation(fields: [adminId], references: [id])
  adminId     Int
  message     String
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

// Configuración global de empresa (singleton: id = 1 siempre)
model CompanySettings {
  id                    Int                 @id @default(1)
  companyName           String              @default("Mi Empresa")
  ruc                   String?
  timezone              String              @default("America/Lima")
  // Tolerancia y descuento por tardanza
  lateTolerance         Int                 @default(0)   // minutos de gracia
  lateDiscountPolicy    LateDiscountPolicy  @default(BY_MINUTE)
  // Horas extra
  overtimeEnabled       Boolean             @default(false)
  overtimeBeforeMinutes Int                 @default(0)   // minutos antes del turno que cuentan
  overtimeAfterMinutes  Int                 @default(0)   // minutos después del turno que cuentan
  overtimeRoundMinutes  Int                 @default(15)  // redondeo de horas extra
  // Almuerzo
  lunchDurationMinutes  Int                 @default(60)
  lunchDeductionType    LunchDeductionType  @default(FIXED)
  lunchRequired         Boolean             @default(false)
  // Ventanas de marcación (Sprint 5)
  entryWindowStart      String              @default("05:00")
  entryWindowEnd        String              @default("11:00")
  lunchWindowStart      String              @default("11:00")
  lunchWindowEnd        String              @default("15:30")
  exitWindowStart       String              @default("15:00")
  exitWindowEnd         String              @default("23:00")
  maxMarksPerDay        Int                 @default(4)
  lunchSkipHours        Int                 @default(4)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model AuditLog {
  id         Int          @id @default(autoincrement())
  actor      User?        @relation("ActorAuditLogs", fields: [actorId], references: [id])
  actorId    Int?
  actorRole  String?      // snapshot del rol en el momento de la acción
  action     String       // CREATE, UPDATE, DELETE, ACCESS_ATTEMPT, QR_REGEN, etc.
  resource   String       // COLLABORATOR, SCHEDULE, ACCESS, USER, etc.
  resourceId String?
  status     AuditStatus
  error      String?
  before     Json?
  after      Json?
  reason     String?
  metadata   Json?        // IP, fingerprint, etc.
  createdAt  DateTime     @default(now())

  @@index([actorId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@index([action, status])
}
